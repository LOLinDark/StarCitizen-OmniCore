AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<optional-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<optional-aws-secret-access-key>
GEMINI_API_KEY=<your-gemini-api-key>
MAX_DAILY_REQUESTS=20
MAX_HOURLY_REQUESTS=5
COST_ALERT_THRESHOLD=10.0
YT_DOWNLOAD_DIR=G:/My Drive/Gaming/Star Citizen/StarCitizenTV
YT_DLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg

VITE_API_BASE_URL=http://localhost:3001
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENDPOINT=http://localhost:3001/api/analytics/events
VITE_ANALYTICS_APP_ID=omni-core
VITE_ANALYTICS_FLUSH_INTERVAL_MS=30000
VITE_PERF_MONITORING_ENABLED=true